#keycloak rtcstats-visualizer
KEYCLOAK_ENABLED=true
KEYCLOAK_AUTH_SERVER_URL=https://iam.hqnb.local
KEYCLOAK_REDIRECT_URI=https://meet.hqnb.local/rtc-visualizer/keycloak/callback
PUBLIC_BASE_PATH=/rtc-visualizer
#config mongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root
#config rtcstats server
RTCSTATS_HTTPS=false

#rtc ai analysis
GEMMA_API_URL=http://10.1.6.52:8004/v1/chat/completions
GEMMA_MODEL=google/gemma-4-26b-a4b-it
# Set the service type. Can be "AWS" or "MongoDB".
RTCSTATS_SERVICE_TYPE=MongoDB

# For MongoDB
RTCSTATS_MONGODB_URI=mongodb://root:root@mongodb.meet.jitsi:27017
RTCSTATS_MONGODB_NAME=rtcstats-db
RTCSTATS_METADATA_COLLECTION=rtcstats-meta-collection
RTCSTATS_GRIDFS_BUCKET=rtcstats-dump-file-bucket

# Enable rtcstats analytics (uncomment to enable)
RTCSTATS_ENABLED=false

# Send the console logs to the rtcstats server
RTCSTATS_STORE_LOGS=true

# The interval at which rtcstats will poll getStats, defaults to 10000ms.
RTCSTATS_POLL_INTERVAL=10000

# Send the SDP to the rtcstats server
RTCSTATS_SEND_SDP=true

# image rtc stats visualizer
RTC_VISUALIZER_IMAGE=registry.cmcati.vn/jitsi-meet/rtc-visualizer:v0906
#file-sharing config
FILE_SHARING_URL=http://10.1.6.53:9098/v1/documents
#LOG_LEVEL=debug
#nginx config
NGINX_WORKER_CONNECTIONS=20000
NGINX_WORKER_PROCESSES=auto
#stt config
AUTO_SPEECH_TO_TEXT=true
#chat config
PROSODY_ENABLE_FILTER_MESSAGES=true
### jigasi config voice and minio
#### - voice
#TRANSLATE_ENDPOINT=http://10.2.6.20:8119/translate
VOICE_WS=https://stream-voices.cmcati.vn
AI_SERVICE=gemma
TRANSLATE_ENDPOINT=http://10.2.6.20:8000/translate/text
#### - minio
MINIO_SERVER=http://10.2.6.25:9015
MINIO_ACCESS_KEY=gR8zCgD0Ld0wMZkAGuei
MINIO_SECRET_KEY=jWLIWZqrVdEZ13phmrqNQX53IqHssNacn0vaJpXv
MINIO_BUCKET_AUDIO=dev-audio-meeting
MINIO_BUCKET_TXT=dev-txt-meeting

### env keycloak
ADAPTER_INTERNAL_URL=http://keycloak-adapter:9000
KEYCLOAK_ORIGIN=https://iam.hqnb.local
KEYCLOAK_ORIGIN_INTERNAL=http://10.1.6.35:8081
KEYCLOAK_REALM=cmeet-dev
KEYCLOAK_CLIENT_ID=c-meet-online
KEYCLOAK_MODE=query
JWT_ALG=HS256
JWT_HASH=SHA-256
JWT_APP_ID=app_id
JWT_APP_SECRET=app_secret
JWT_EXP_SECOND=604800
CMEET_SERVER_MANAGER_API=https://cmeet.cmcati.vn
ALLOW_UNSECURE_CERT=true
HOSTNAME=0.0.0.0
PORT=9000
#endpoint statistic participant's time in conference
ENDPOINT_STATS=http://10.1.6.53:8884/cmeet-server-manager/api/meeting-online-log

#grafana config
GF_SECURITY_ADMIN_USER=admin@cmc.com
GF_SECURITY_ADMIN_PASSWORD=CMC@TI2o25
GF_SERVER_ROOT_URL=https://meet.hqnb.local/grafana/
JVB_ENABLE_METRICS=true
PROSODY_ENABLE_METRICS=true


#api key google translate
GOOGLE_API_KEY=default

#config default display name
DEFAULT_REMOTE_DISPLAY_NAME='CMC ATIer'
#
# Directory where all configuration will be stored
CONFIG=~/.jitsi-meet-cfg

#domain c-meet
DOMAIN=meet.hqnb.local
# Exposed HTTP port (will redirect to HTTPS port)
HTTP_PORT=8088

# Exposed HTTPS port
HTTPS_PORT=8443

# System time zone
TZ=Asia/Ho_Chi_Minh

# Public URL for the web service (required)
# Keep in mind that if you use a non-standard HTTPS port, it has to appear in the public URL
PUBLIC_URL=https://meet.hqnb.local

#config jibri
LOCAL_ADDRESS=10.1.6.35
IGNORE_CERTIFICATE_ERRORS=true
JIBRI_HTTP_API_EXTERNAL_PORT=2222
JIBRI_HTTP_API_INTERNAL_PORT=3333
XMPP_ENV_NAME=xmpp.meet.jitsi
ENABLE_COLIBRI_WEBSOCKET=1
ENABLE_RECORDING=1
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=jibri
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_XMPP_USER=jibri
JIBRI_STRIP_DOMAIN_JID=muc
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_PENDING_TIMEOUT=90
JIBRI_FINALIZE_RECORDING_SCRIPT_PATH=/usr/local/bin/jibri-minio.sh
#VIDEOBRIDGE_MAX_MEMORY=3072m
XMPP_AUTH_DOMAIN=auth.meet.jitsi
ENABLE_MODERATOR_CHECKS=false
#
ENABLE_SHARED_DOCUMENT_RANDOM_NAME=1
# Enable Let's Encrypt certificate generation
ENABLE_LETSENCRYPT=0

DOCKER_HOST_ADDRESS=10.1.6.35
JVB_ADVERTISE_IPS=10.1.6.35
#ETHERPAD_PUBLIC_URL=https://etherpad.my.domain/p/
ENABLE_AUTH=1
ENABLE_AUTH_JICOFO=0
ENABLE_AUTH_PROSODY=1
JICOFO_ENABLE_AUTH=1
#JICOFO_AUTH_TYPE=xmpp
ENABLE_AUTO_LOGIN=0
JICOFO_AUTH_LIFETIME=100 milliseconds
ENABLE_AUTO_OWNER=0
ENABLE_VISITORS=1
PROSODY_AUTH_TYPE=jwt
#JWT_APP_SECRET=1
#JWT_APP_SECRET=true
# Set the excalidraw-backend URL in the docker local network (uncomment to enable)
ENABLE_P2P=0
#P2P_STUN_SERVERS=meet-jit-si-turnrelay.jitsi.net:443
# Set the excalidraw-backend public URL (uncomment to enable)
WHITEBOARD_COLLAB_SERVER_URL_BASE=http://whiteboard.meet.jitsi
WHITEBOARD_COLLAB_SERVER_PUBLIC_URL=https://meet.hqnb.local
WHITEBOARD_ENABLED=1
WHITEBOARD_DOMAIN=whiteboard.meet.jitsi
# Basic Jigasi configuration options (needed for SIP gateway support)
#
ENABLE_TRANSCRIPTIONS=1

# Enable guest access (if authentication is enabled, this allows for users to be held in lobby until registered user lets them in)
ENABLE_GUESTS=1

#LDAP_BINDPW=LdapUserPassw0rd
TOKEN_AUTH_URL=https://meet.hqnb.local/static/oidc-pre-auth.html?path={room}&room={room}&state={state}
TOKEN_LOGOUT_URL=https://iam.hqnb.local/realms/cmeet-dev/protocol/openid-connect/logout?client_id=c-meet-online&post_logout_redirect_uri=https://meet.hqnb.local

